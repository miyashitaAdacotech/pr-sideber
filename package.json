{
	"name": "pr-sidebar",
	"private": true,
	"type": "module",
	"version": "0.0.1",
	"scripts": {
		"dev": "vite",
		"build": "GITHUB_CLIENT_ID=Ov23liCgU4UCzg03tnCK vite build",
		"build:wasm": "cd rust-core/crates/adapter-wasm && wasm-pack build --target web",
		"build:all": "pnpm build:wasm && pnpm build",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint:svelte": "eslint \"src/**/*.svelte\"",
		"format": "biome format --write .",
		"lint": "biome check .",
		"depcruise": "depcruise src --config .dependency-cruiser.cjs",
		"prepare": "husky"
	},
	"dependencies": {
		"svelte": "^5.0.0"
	},
	"lint-staged": {
		"*.{ts,js,cjs,mjs,json}": "biome check --write --no-errors-on-unmatched",
		"*.rs": "bash -c 'cd rust-core && cargo fmt'"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@crxjs/vite-plugin": "^2.0.0-beta.30",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"@tsconfig/svelte": "^5.0.0",
		"@types/chrome": "^0.1.38",
		"@types/node": "^25.5.0",
		"dependency-cruiser": "^17.3.9",
		"eslint": "^9.0.0",
		"eslint-plugin-svelte": "^3.0.0",
		"husky": "^9.1.7",
		"jsdom": "^29.0.1",
		"lint-staged": "^16.4.0",
		"svelte-check": "^4.0.0",
		"typescript": "^5.5.0",
		"typescript-eslint": "^8.57.1",
		"vite": "^6.0.0",
		"vitest": "^3.0.0"
	}
}
