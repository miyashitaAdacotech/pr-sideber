{
	"permissions": {
		"allow": [
			"Bash(git add:*)",
			"Bash(git commit:*)",
			"Bash(git push:*)",
			"Bash(gh repo:*)",
			"Bash(gh issue:*)",
			"Bash(gh label:*)",
			"Bash(gh auth status:*)",
			"Bash(gh api graphql:*)",
			"Bash(gh api repos/:*)",
			"Bash(gh api /repos/:*)",
			"Bash(gh api -X DELETE repos/:*)",
			"Bash(gh api -X DELETE /repos/:*)"
		],
		"deny": [
			"Bash(gh auth token:*)",
			"Bash(gh auth login:*)",
			"Bash(gh auth logout:*)",
			"Bash(gh auth refresh:*)",
			"Bash(gh auth setup-git:*)",
			"Read(.envrc)",
			"Read(.claude/settings.local.json)",
			"Bash(cat .envrc)",
			"Bash(less .envrc)",
			"Bash(head .envrc)",
			"Bash(tail .envrc)",
			"Bash(source .envrc)",
			"Bash(grep .envrc)",
			"Bash(*$GH_*)",
			"Bash(*${GH_*)",
			"Bash(printenv)",
			"Bash(env | grep)",
			"Bash(direnv exec)",
			"Bash(direnv export)"
		]
	},
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "bash .claude/hooks/pre-command-secret-check.sh"
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Write|Edit",
				"hooks": [
					{
						"type": "command",
						"command": "bash .claude/hooks/post-edit-ts.sh"
					},
					{
						"type": "command",
						"command": "bash .claude/hooks/post-edit-rust.sh"
					}
				]
			}
		],
		"SessionStart": [
			{
				"matcher": "startup",
				"hooks": [
					{
						"type": "command",
						"command": "bash .claude/hooks/session-start.sh"
					}
				]
			}
		]
	}
}
